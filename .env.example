# Telegram Bot Configuration
# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID to receive notifications (can be your user ID or group chat ID)
NOTIFICATION_CHAT_ID=your_chat_id_here

# Telegram bots to ping (comma-separated chat IDs)
# These are the chat IDs of bots you want to monitor
TELEGRAM_BOTS_TO_PING=@your_bot1, @your_bot2

# Bot that requires extra /checkbell verification after ping succeeds
ANOMALOUS_BOT=@your_bot

# Personal Telegram account credentials (from https://my.telegram.org)
# Used to send ping messages to monitored bots as a real user
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+15551234567
TELETHON_SESSION_PATH=./data/telegram_session


# IP addresses or domain names to ping (comma-separated)
IP_ADDRESSES_TO_PING=example.com, 192.168.1.1

# Websites to check via HTTP (comma-separated full URLs)
WEBSITES_TO_CHECK=https://example.com, https://myapp.example.com

# NTRIP casters to check (comma-separated, e.g. http://host:2101)
NTRIP_CASTERS_TO_CHECK=http://rtk.example.com:2101

# Systemd services to monitor (comma-separated)
SYSTEMD_SERVICES=nginx, myapp

# Check interval in hours (default: 24)
CHECK_INTERVAL_HOURS=24

# Ping timeout in seconds (default: 5)
PING_TIMEOUT=5

# Telegram response timeout in seconds (default: 30)
TELEGRAM_RESPONSE_TIMEOUT=30
